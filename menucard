<!doctype html>
<html>
  <head>
    <title>Hotel Menu</title>
    <style>
      body {
        font-family: sans-serif;
      }
      h1 {
        color: #333;
        text-align: center;
      }
      table {
        width: 60%;
        margin: 20px auto;
        border-collapse: collapse;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      }
      th,
      td {
        border: 1px solid:#ddd;
        padding: 12px;
        text-align: left;
      }
      th {
        background-color: #f4f4f4;
        color: #555;
      }
      tr:nth-child(even) {
        background-color: #f9f9f9;
      }
    </style>
  </head>
  <body style="background-color: blue; background-image: url(menu.avif)">
    <h1>The Grand Hotel Menu</h1>

    <table>
      <thead>
        <tr>
          <th
            style="
              border: 2px solid blue;
              padding: 10px;
              background-color: lightgrey;
            ">
            Item Name
          </th>
          <th
            style="
              border: 2px solid:blue;
              padding: 10px;
              background-color: lightgrey;
            ">
            Price
          </th>
        </tr>
      </thead>
      <tbody>
        <!-- Lunch Items -->
        <tr>
          <td>Panner Biryani</td>
          <td>230</td>
        </tr>
        <tr>
          <td>Egg Biryani</td>
          <td>250</td>
        </tr>
        <tr>
          <td>Shawerma(Panner)</td>
          <td>190</td>
        </tr>

        <tr>
          <td>Shawerma(Chicken)</td>
          <td>180</td>
        </tr>
        <tr>
          <td>Butter Chicken</td>
          <td>220</td>
        </tr>
        <!-- Dinner Items -->
        <tr>
          <td>2-Parotas and chicken curry (Andhra/Telangana)</td>
          <td>100</td>
        </tr>
        <tr>
          <td>Chicken Dum Biryani</td>
          <td>300</td>
        </tr>
        <!-- Desserts -->
        <tr>
          <td>Chocalate Lava Cake</td>
          <td>200</td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
